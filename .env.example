# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=AIza...
REACT_APP_FIREBASE_AUTH_DOMAIN=dripro-xxxxx.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=dripro-xxxxx
REACT_APP_FIREBASE_STORAGE_BUCKET=dripro-xxxxx.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef

# FCM VAPID Key
REACT_APP_VAPID_KEY=BNxxxxxxx...

# Amazon SES (for GitHub Actions)
AWS_ACCESS_KEY_ID=AKIAxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxx
AWS_REGION=ap-northeast-1
SES_FROM_EMAIL=noreply@yourdomain.com

# Firebase Admin SDK (for push_sender.py)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
